# ==========================================
# OSS Network (OSSN) Master .gitignore
# ==========================================

# --- General / OS ---
.DS_Store
*.log
.vscode/
.idea/
*.swp
__pycache__/
node_modules/
package-lock.json
*.code-workspace

# --- Environment & Secrets (CRITICAL) ---
# Never commit your credentials or DB passwords!
.env
.env.*
!.env.example
secrets.json

# --- Infrastructure & Database ---
# Local database storage for PostgreSQL
pgdata/
docker_volumes/

# --- Backend (FastAPI / Python) ---
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/*.db
backend/*.sqlite
backend/*.sqlite3
backend/.pytest_cache/
backend/.venv/
backend/dist/
backend/build/
# If you use Pixi for backend management
backend/.pixi/

# --- Frontend (NextJS) ---
frontend/node_modules/
frontend/dist/
frontend/.angular/
frontend/coverage/
frontend/npm-debug.log*
frontend/yarn-error.log*
frontend/.editorconfig
# If you use Pixi for frontend management
frontend/.pixi/

# --- Management Tools (Pixi) ---
# Ignore the environment prefix created by Pixi
.pixi/

# --- Docker ---
# Ignore generated docker-compose overrides if necessary
docker-compose.override.yml